# Local Postgres for Drizzle.
DATABASE_URL=postgres://casper_gw:casper_gw@127.0.0.1:5432/casper_gw

# CSPR.cloud REST and hosted x402 facilitator. Keep the access token server-side.
CSPR_CLOUD_API_KEY=
CSPR_CLOUD_REST_BASE_URL=https://api.testnet.cspr.cloud
CSPR_CLOUD_STREAMING_BASE_URL=wss://streaming.testnet.cspr.cloud
CSPR_X402_FACILITATOR_URL=https://x402-facilitator.cspr.cloud

# Operator-only HTTP controls for routes that can call server-side integrations.
CASPER_GW_OPERATOR_TOKEN=
CASPER_GW_HTTP_SIGNING_ENABLED=false

# Base URL used only by the manual hosted endpoint live-smoke signer.
CASPER_GW_HOSTED_SMOKE_BASE_URL=http://localhost:3000

# Casper Testnet x402 payment configuration.
CASPER_NETWORK=casper:casper-test
CASPER_NODE_RPC_URL=https://node.testnet.casper.network/rpc
CASPER_PAYMENT_ASSET_PACKAGE=3d80df21ba4ee4d66a2a1f60c32570dd5685e4b279f6538162a5fd1314847c1e
CASPER_PAYMENT_ASSET_NAME="Wrapped CSPR"
CASPER_PAYMENT_ASSET_SYMBOL=WCSPR
CASPER_PAYMENT_ASSET_DECIMALS=9
CASPER_PAYMENT_AMOUNT=7500000000
CASPER_PAYMENT_TIMEOUT_SECONDS=900
CASPER_PAYEE_ACCOUNT_HASH=

# Local Testnet signer for integration verification only. Do not use for production custody.
# Prefer a local ignored PEM file path over multiline private key env content.
CASPER_TESTNET_SIGNER_PRIVATE_KEY_PEM_PATH=
CASPER_TESTNET_SIGNER_PRIVATE_KEY_PEM=
CASPER_TESTNET_SIGNER_KEY_ALGO=secp256k1

# Operator wrap command for preparing the signer with WCSPR before live x402 smoke.
CASPER_WCSPR_WRAP_AMOUNT=15000000000
CASPER_WCSPR_DEPOSIT_PAYMENT_AMOUNT=5000000000

# Provider source used by Phase 0 discovery/call.
CSPR_TRADE_MCP_URL=https://mcp.cspr.trade/mcp
