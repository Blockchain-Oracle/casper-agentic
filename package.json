{
  "name": "casper-agent-commerce-gateway",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:browser": "playwright test",
    "test:browser:csprclick": "playwright test --config=playwright.csprclick.config.ts",
    "guard:files": "node scripts/check-file-lines.mjs",
    "guard:product": "node scripts/guard-product-scope.mjs",
    "guard:secrets": "node scripts/guard-secrets.mjs",
    "guard:workflows": "node scripts/guard-workflows.mjs",
    "verify": "pnpm guard:files && pnpm guard:product && pnpm guard:secrets && pnpm guard:workflows && pnpm test && pnpm typecheck && pnpm lint",
    "ci": "pnpm install --frozen-lockfile && pnpm verify && pnpm test:browser && pnpm test:browser:csprclick && pnpm build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "maintenance:prune-feed": "tsx scripts/prune-external-feed-state.ts",
    "smoke:live": "tsx scripts/live-smoke.ts",
    "ensure:wcspr": "tsx scripts/ensure-wcspr-liquidity.ts",
    "wrap:wcspr": "tsx scripts/wrap-wcspr.ts"
  },
  "dependencies": {
    "@make-software/casper-x402": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@next/env": "16.2.9",
    "@x402/core": "^2.16.0",
    "@x402/fetch": "^2.16.0",
    "casper-js-sdk": "^5.0.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.21.0",
    "motion": "^12.42.0",
    "nanoid": "^5.1.16",
    "next": "16.2.9",
    "openapi-mcp-generator": "^4.0.1",
    "postgres": "^3.4.9",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "simple-icons": "^16.24.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.15"
    }
  },
  "devDependencies": {
    "@make-software/csprclick-core-types": "^2.1.0",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
